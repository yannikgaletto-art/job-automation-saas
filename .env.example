# ============================================
# PATHLY V2.0 - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# ============================================
# Last Updated: 2026-04-12
# ============================================

# ============================================
# 1. SUPABASE (DATABASE & AUTH) — REQUIRED
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 2. APP CONFIGURATION — REQUIRED
# ============================================
NEXT_PUBLIC_APP_URL=https://app.path-ly.eu
NEXT_PUBLIC_WEBSITE_URL=https://path-ly.eu
NODE_ENV=development

# ============================================
# 3. AI MODELS — REQUIRED
# ============================================

# Anthropic (Claude Sonnet 4.5 & Haiku 4.5)
ANTHROPIC_API_KEY=

# Mistral (EU-native, DSGVO-konform — Stufe 1 Tasks)
MISTRAL_API_KEY=

# Perplexity (Company Research — Sonar Pro)
PERPLEXITY_API_KEY=

# OpenAI (Whisper transcription for coaching)
OPENAI_API_KEY=

# ============================================
# 4. SCRAPING — REQUIRED (at least SerpAPI + Jina)
# ============================================

# SerpAPI (Job Search — structured Google Jobs data)
SERPAPI_KEY=

# Jina Reader (HTML to Markdown conversion)
JINA_READER_API_KEY=

# Firecrawl (Deep ATS scraping — Greenhouse/Lever/Workday)
FIRECRAWL_API_KEY=

# ============================================
# 5. SECURITY — REQUIRED
# ============================================

# Encryption Key (Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Admin API Secret (Generate: openssl rand -hex 32)
# Used by /api/admin/cost-report endpoint
ADMIN_SECRET=

# ============================================
# 6. PAYMENTS — STRIPE — REQUIRED
# ============================================

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Price IDs — Server-side (webhook validation)
STRIPE_STARTER_MONTHLY_PRICE=price_xxx
STRIPE_STARTER_QUARTERLY_PRICE=price_xxx
STRIPE_DURCHSTARTER_MONTHLY_PRICE=price_xxx
STRIPE_DURCHSTARTER_QUARTERLY_PRICE=price_xxx
STRIPE_TOPUP_PRICE=price_xxx

# Price IDs — Client-side (upgrade page, topup buttons)
NEXT_PUBLIC_STRIPE_STARTER_MONTHLY_PRICE=price_xxx
NEXT_PUBLIC_STRIPE_STARTER_QUARTERLY_PRICE=price_xxx
NEXT_PUBLIC_STRIPE_DURCHSTARTER_MONTHLY_PRICE=price_xxx
NEXT_PUBLIC_STRIPE_DURCHSTARTER_QUARTERLY_PRICE=price_xxx
NEXT_PUBLIC_STRIPE_TOPUP_PRICE=price_xxx

# ============================================
# 7. BACKGROUND JOBS — INNGEST — REQUIRED
# ============================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================
# 8. RATE LIMITING — UPSTASH REDIS — REQUIRED
# ============================================
# Without these, rate limiting is DISABLED (pass-through fallback)
# CRITICAL: Use EU region on Upstash for DSGVO compliance
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ============================================
# 9. DOCUMENT INTELLIGENCE — AZURE — REQUIRED
# ============================================
# Region: West Europe (DSGVO-konform)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ============================================
# 10. COMMUNICATION — RESEND
# ============================================
RESEND_API_KEY=

# ============================================
# 11. ANALYTICS — POSTHOG (EU) — RECOMMENDED
# ============================================
# DSGVO: EU endpoint, localStorage (no cookies), all inputs masked
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============================================
# 12. ERROR MONITORING — SENTRY — RECOMMENDED
# ============================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============================================
# 13. AI OBSERVABILITY — HELICONE — OPTIONAL
# ============================================
# Transparent proxy for Anthropic cost tracking
# Requires DPA before production use (US-based processor)
HELICONE_API_KEY=

# ============================================
# 14. CHROME EXTENSION — OPTIONAL
# ============================================
NEXT_PUBLIC_EXTENSION_ID=

# ============================================
# 15. VERCEL — AUTO-POPULATED
# ============================================
# VERCEL_URL is auto-set by Vercel in production
# VERCEL_URL=your-app.vercel.app
