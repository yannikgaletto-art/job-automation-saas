# ===================================================================
# .env.test — E2E Test Environment Variables
#
# KOPIEREN als .env.test (gleicher Ordner) und Werte setzen.
# .env.test ist in .gitignore — KEIN Commit dieser Datei!
# ===================================================================

# Vercel-Preview-URL des aktuellen Branch.
# Format: https://pathly-git-<branch>-<team>.vercel.app
# Yannik liefert dir diese URL.
E2E_BASE_URL=https://pathly-git-main-XXXX.vercel.app

# Supabase-Projekt (gleiche DB wie Production — VORSICHT)
# Aus Vercel-Env-Vars: NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://XXXX.supabase.co

# Service-Role-Key — NUR in dieser Datei, NIEMALS commiten.
# Aus Supabase Dashboard → Project Settings → API → service_role secret
# Power: kann RLS umgehen, alle Tables lesen + schreiben.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Test-User-Pattern.
# Cleanup-Skripte löschen alle auth.users mit dieser Email-Endung.
# NIEMALS auf eine echte User-Domain ändern.
TEST_USER_EMAIL_PATTERN=anna.mueller.test+e2e

# Test-User-Passwort (gleich für alle Test-Accounts dieses Runs)
TEST_USER_PASSWORD=Test-Pathly-2026-NotASecret!

# Optionaler Slack/Discord-Webhook für Reports (lass leer wenn nicht gewünscht)
TEST_REPORT_WEBHOOK=

# Optional: Vercel Deployment Protection Bypass für Playwright.
# Vercel → Settings → Deployment Protection → Protection Bypass for Automation.
# Wird als Header `x-vercel-protection-bypass` gesendet.
VERCEL_AUTOMATION_BYPASS_SECRET=
